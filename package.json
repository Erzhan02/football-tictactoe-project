{
  "name": "football-ttt-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n FRONT,SERVER -c cyan,yellow \"npm run dev --workspace=frontend\" \"npm run dev --workspace=server\"",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "db:studio": "npm run db:studio --workspace=server",
    "db:import": "npm run db:import --workspace=server",
    "db:enrich": "npm run db:enrich --workspace=server",
    "build": "npm run build --workspace=frontend && npm run build --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
